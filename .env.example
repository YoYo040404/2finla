# Custom request form — lead capture
# Copy this file to .env.local and fill in real values.
# .env.local is gitignored and must never be committed.

# Resend API key — https://resend.com/api-keys
RESEND_API_KEY=re_REPLACE_WITH_YOUR_KEY

# Email address that receives custom request leads
LEAD_EMAIL_TO=your-lead-inbox@example.com

# From address.
# Sandbox (no DNS setup): onboarding@resend.dev
# Production: a domain verified on Resend, e.g. leads@2tjewelers.com
LEAD_EMAIL_FROM=onboarding@resend.dev
